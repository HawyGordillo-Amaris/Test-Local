@api = https://steady-shrimp-32.hasura.app/v1/graphql
@admin_secret = 

### Productos - 1) Listar
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "query ListarProductos { productos(order_by: {id: asc}) { id nombreProducto ean } }"
}

###

### Productos - 2) Obtener por ID
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "query ProductoPorId($id: Int!) { productos_by_pk(id: $id) { id nombreProducto ean } }",
  "variables": { "id": 1 }
}

###

### Productos - 3) Crear
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "mutation CrearProducto($obj: productos_insert_input!) { insert_productos_one(object: $obj) { id nombreProducto ean } }",
  "variables": {
    "obj": { "nombreProducto": "Mouse", "ean": "999999" }
  }
}

###

### Productos - 4) Actualizar
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "mutation ActualizarProducto($id: Int!, $set: productos_set_input!) { update_productos_by_pk(pk_columns: {id: $id}, _set: $set) { id nombreProducto ean } }",
  "variables": {
    "id": 1,
    "set": { "nombreProducto": "Computador 1 Toshiba (Editado)" }
  }
}

###

### Productos - 5) Eliminar
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "mutation EliminarProducto($id: Int!) { delete_productos_by_pk(id: $id) { id } }",
  "variables": { "id": 9999 }
}

###
###
### Bodegas - 1) Listar
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "query ListarBodegas { bodegas(order_by: {id: asc}) { id codigo nombreBodega } }"
}

###

### Bodegas - 2) Obtener por ID
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "query BodegaPorId($id: Int!) { bodegas_by_pk(id: $id) { id codigo nombreBodega } }",
  "variables": { "id": 1 }
}

###

### Bodegas - 3) Crear
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "mutation CrearBodega($obj: bodegas_insert_input!) { insert_bodegas_one(object: $obj) { id codigo nombreBodega } }",
  "variables": {
    "obj": { "codigo": "BOD-03", "nombreBodega": "Bodega Prueba Cali" }
  }
}

###

### Bodegas - 4) Actualizar
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "mutation ActualizarBodega($id: Int!, $set: bodegas_set_input!) { update_bodegas_by_pk(pk_columns: {id: $id}, _set: $set) { id codigo nombreBodega } }",
  "variables": {
    "id": 1,
    "set": { "nombreBodega": "Bodega Prueba Bogotá (Editado)" }
  }
}

###

### Bodegas - 5) Eliminar
POST {{api}}
Content-Type: application/json
x-hasura-admin-secret: {{admin_secret}}

{
  "query": "mutation EliminarBodega($id: Int!) { delete_bodegas_by_pk(id: $id) { id } }",
  "variables": { "id": 9999 }
}
